# Production (Render PostgreSQL) — Render auto-fills DATABASE_URL
DATABASE_URL=postgresql://crm:crm_secret@localhost:5432/pss_crm

JWT_SECRET=change-this-to-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
PORT=4000
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
USE_REDIS=false

# Public URL for WhatsApp photo send (production = your Render API URL)
PUBLIC_API_URL=http://localhost:4000
MEDIA_MAX_BYTES=10485760

# Optional Redis (Docker: docker compose up -d)
# REDIS_URL=redis://localhost:6379
# USE_REDIS=true
